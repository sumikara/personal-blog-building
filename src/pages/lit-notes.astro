---
import BaseLayout from '../components/BaseLayout.astro';
import RetroWindow from '../components/RetroWindow.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog')).filter(p=>p.data.category==='lit_notes');
---
<BaseLayout title="lit_notes | Maymun Ne Yapıyor?"><RetroWindow title="/lit_notes"><p>Kitaplar, cümleler, karakterler, denemeler ve edebi kırıntılar.</p><p><a href="/archive">← archive</a></p><div class="post-grid">{posts.map((post)=><PostCard post={post} />)}</div></RetroWindow></BaseLayout>
