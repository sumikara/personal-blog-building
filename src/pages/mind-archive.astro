---
import BaseLayout from '../components/BaseLayout.astro';
import RetroWindow from '../components/RetroWindow.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog')).filter(p=>p.data.category==='mind_archive');
---
<BaseLayout title="mind_archive | Maymun Ne Yapıyor?"><RetroWindow title="/mind_archive"><p>Psikoloji, rüyalar, bilinç, kişisel dönüşüm ve zihinde açık kalan sekmeler.</p><p><a href="/archive">← archive</a></p><div class="post-grid">{posts.map((post)=><PostCard post={post} />)}</div></RetroWindow></BaseLayout>
