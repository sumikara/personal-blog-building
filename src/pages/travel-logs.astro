---
import BaseLayout from '../components/BaseLayout.astro';
import RetroWindow from '../components/RetroWindow.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog')).filter(p=>p.data.category==='travel_logs');
---
<BaseLayout title="travel_logs | Maymun Ne Yapıyor?"><RetroWindow title="/travel_logs"><p>Şehirler, sokaklar, kültür, yolculuklar ve yaşama ihtimalleri.</p><p><a href="/archive">← archive</a></p><div class="post-grid">{posts.map((post)=><PostCard post={post} />)}</div></RetroWindow></BaseLayout>
